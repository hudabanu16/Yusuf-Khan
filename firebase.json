          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "salman-1ce8f",
          "appId": "1:538647707022:ios:7666a27060de7c8843f8df",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "macos": {
        "default": {
          "projectId": "salman-1ce8f",
          "appId": "1:538647707022:ios:7666a27060de7c8843f8df",
          "uploadDebugSymbols": false,
          "fileOutput": "macos/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "salman-1ce8f",
          "configurations": {
            "android": "1:538647707022:android:44159bf4d817937543f8df",
            "ios": "1:538647707022:ios:7666a27060de7c8843f8df",
            "macos": "1:538647707022:ios:7666a27060de7c8843f8df",
